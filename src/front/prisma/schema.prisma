generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}



model SourceFile {
  id          String   @id @default(cuid())

  name        String
  path        String   @unique
  hash        String?  // pour détecter changements dataset

  importedAt  DateTime @default(now())

  deputies    Deputy[]
  laws        Law[]
  dossiers    Dossier[]
  amendments  Amendment[]
  debates     Debate[]
}


//
// 🏛️ Député
//
model Deputy {
  id        String   @id @default(cuid())

  uid       String?  @unique // 🔥 AN ID
  name      String
  group     String?

  raw       Json?
  sourceId  String?
  source    SourceFile? @relation(fields: [sourceId], references: [id])

  votes     Vote[]
  amendments Amendment[]
  debates   Debate[]

  createdAt DateTime @default(now())
}



//dossiers


model Dossier {
  id        String   @id @default(cuid())

  uid       String?  @unique // AN reference
  title     String?

  raw         Json?    // 👈 IMPORTANT

  sourceId  String?
  source    SourceFile? @relation(fields: [sourceId], references: [id])

  laws      Law[]


  createdAt DateTime @default(now())
}




//
// 📜 Loi (document principal)
//
model Law {
  id          String   @id @default(cuid())

  uid         String?  @unique // AN reference

  externalId  String   @unique // ✅ VRAI champ de mapping AN
  
  title       String
  description String?

  raw         Json?    // 👈 IMPORTANT

  status      LawStatus @default(DRAFT)

  dossierId   String?
  dossier     Dossier? @relation(fields: [dossierId], references: [id])

  sourceId    String?
  source      SourceFile? @relation(fields: [sourceId], references: [id])

  versions    LawVersion[]
  amendments  Amendment[]
  debates     Debate[]
  votes       Vote[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // jointure Dossier -> Law -> Amendment sur toutes les pages
  @@index([dossierId])
}

//
// 🧬 Version de loi (Git-like history)
//
model LawVersion {
  id        String   @id @default(cuid())

  version   Int
  content   String   // snapshot complet ou diff

  lawId     String
  law       Law @relation(fields: [lawId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

//
// 📄 Texte articulé d'une version (parsé depuis le HTML opendata AN)
//    -> sert au diff avant/après réel entre versions successives
//
model LawText {
  id         String @id @default(cuid())

  versionUid String @unique // uid AN du document (= Law.externalId)
  dossierUid String // dossier auquel appartient cette version
  ordre      Int // ordre chronologique dans le parcours
  label      String // ex: "Texte de la commission (AN, 1ère lecture)"
  date       String?

  articles   Json // { "Article 1er": ["alinéa 1", "alinéa 2", ...], ... }

  createdAt  DateTime @default(now())

  @@index([dossierUid])
}

//
// ✍️ Amendement
//
model Amendment {
  id        String @id @default(cuid())

  uid       String @unique

  rawJson   Json

  numeroLong String?
  numeroOrdreDepot String?
  prefixeOrganeExamen String?
  examenRef String?
  texteLegislatifRef String?

  article   String?
  alinea    String?

  title     String?
  content   String?

  // Ajoutés par backfill depuis les fichiers sources AN (exposé + cosignataires).
  exposeSommaire String?
  cosignataires  String[]

  status    AmendmentStatus @default(PENDING)

  sort      String?
  dateDepot DateTime?
  datePublication DateTime?
  dateSort  DateTime?

  authorId  String?
  deputyId  String?

  deputy    Deputy? @relation(fields: [deputyId], references: [id])

  /// 🔥 IMPORTANT : rendu optionnel pour ingestion safe
  lawId     String?
  law       Law? @relation(fields: [lawId], references: [id])

  sourceId  String?
  source    SourceFile? @relation(fields: [sourceId], references: [id])

  votes     Vote[]

  createdAt DateTime @default(now())

  // Index sur les colonnes de jointure/filtre (Postgres n'indexe pas les FK
  // automatiquement, Prisma non plus) -> évite les scans séquentiels sur ~121k
  // amendements à chaque agrégat de la home / page loi.
  @@index([lawId])
  @@index([authorId])
  @@index([status])
}

//
// 🗳️ Scrutin public (importé du dataset AN "Scrutins"). Les positions
// nominatives par député sont dans la table "ScrutinVote" (interrogée en SQL
// brut pour éviter des millions de lignes côté Prisma).
//
model Scrutin {
  id          String    @id @default(cuid())
  uid         String    @unique
  numero      String?
  dateScrutin DateTime?
  titre       String?
  sortCode    String?
  sortLibelle String?
  pour        Int?
  contre      Int?
  abstention  Int?
  nonVotant   Int?
  dossierUid  String?

  @@index([dossierUid])
}

//
// 🗣️ Débat
//
model Debate {
  id        String   @id @default(cuid())

  content   String

  lawId     String
  law       Law @relation(fields: [lawId], references: [id], onDelete: Cascade)

  deputyId  String?
  deputy    Deputy? @relation(fields: [deputyId], references: [id])

  sourceId  String?
  source    SourceFile? @relation(fields: [sourceId], references: [id])

  createdAt DateTime @default(now())
}

//
// 🗳️ Vote
//
model Vote {
  id        String   @id @default(cuid())

  value     VoteValue

  lawId     String?
  law       Law? @relation(fields: [lawId], references: [id])

  amendmentId String?
  amendment   Amendment? @relation(fields: [amendmentId], references: [id])

  deputyId  String
  deputy    Deputy @relation(fields: [deputyId], references: [id])

  createdAt DateTime @default(now())
}


model EntityEdge {
  id        String @id @default(cuid())

  fromId    String
  toId      String

  type      String // "AMENDS", "VOTES", "PART_OF", etc.

  metadata  Json?
}

//
// 📊 Enums
//
enum LawStatus {
  DRAFT
  IN_DEBATE
  VOTED
  ADOPTED
  REJECTED
}

enum AmendmentStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum VoteValue {
  FOR
  AGAINST
  ABSTAIN
}